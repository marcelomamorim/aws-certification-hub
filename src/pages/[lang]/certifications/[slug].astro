---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import StudyProgress from "../../../components/StudyProgress.astro";
import CertificationStudy from "../../../components/CertificationStudy.astro";
import CertificationQuiz from "../../../components/CertificationQuiz.astro";
import { getCopy, languages, servicesCatalogBase, type Language } from "../../../lib/site";
import { localizedPath } from "../../../lib/paths";
import { getCertificationBySlug, getCertificationSlugs } from "../../../lib/certifications";
import { getQuiz } from "../../../lib/quizzes";

export function getStaticPaths() {
  return languages.flatMap((lang) =>
    getCertificationSlugs().map((slug) => ({ params: { lang, slug } }))
  );
}

const lang = Astro.params.lang as Language;
const slug = Astro.params.slug as string;
const copy = getCopy(lang);
const cert = getCertificationBySlug(lang, slug);

if (!cert) {
  return Astro.redirect(localizedPath(lang, "certifications"));
}

const currentPath = localizedPath(lang, `certifications/${slug}`);
const alternates = languages.map((code) => ({ lang: code, href: localizedPath(code, `certifications/${slug}`) }));

const overviewItems = [
  { label: copy.levelLabel, value: cert.levelLabel },
  { label: copy.durationLabel, value: `${cert.durationMin} ${copy.minutes}` },
  { label: copy.questionsLabel, value: String(cert.questions) },
  { label: copy.passingLabel, value: `${cert.passingScore} (${copy.scoreScale})` },
  { label: copy.costLabel, value: `US$ ${cert.costUsd}` }
];

const hasDeepContent = cert.domains.some((domain) => domain.summary || domain.keyTopics.length > 0);
const quiz = getQuiz(slug, lang);
---

<BaseLayout
  lang={lang}
  title={`${cert.code} — ${cert.name}`}
  description={cert.overview}
  currentPath={currentPath}
  alternates={alternates}
>
  <article class="cert-detail">
    <div class="section-frame">
      <a class="back-link" href={localizedPath(lang, "certifications")}>← {copy.backToCertifications}</a>

      <header class="detail-head">
        <span class="cert-code mono">{cert.code}</span>
        <h1 class="section-title">{cert.name}</h1>
        <p class="section-copy">{cert.overview}</p>
        <StudyProgress lang={lang} itemId={`cert:${cert.code}`} />
      </header>

      <section class="overview surface">
        <h2 class="block-title">{copy.overviewTitle}</h2>
        <dl class="overview-grid">
          {overviewItems.map((item) => (
            <div>
              <dt>{item.label}</dt>
              <dd>{item.value}</dd>
            </div>
          ))}
        </dl>
        <p class="who-for"><strong>{copy.whoForLabel}:</strong> {cert.whoFor}</p>
      </section>

      <CertificationStudy lang={lang} cert={cert} />

      {quiz && <CertificationQuiz lang={lang} cert={cert} questions={quiz} />}

      <section class="domains">
        <h2 class="block-title">{copy.domainsTitle}</h2>
        {!hasDeepContent && <p class="seed-note">{copy.seedNote}</p>}
        <ul class="domain-list">
          {cert.domains.map((domain) => (
            <li class="domain-card surface">
              <div class="domain-top">
                <h3>{domain.name}</h3>
                <span class="weight mono">{domain.weightPct}%</span>
              </div>
              <div class="weight-bar" aria-hidden="true">
                <span style={`width:${domain.weightPct}%`}></span>
              </div>
              {domain.summary && <p class="domain-summary">{domain.summary}</p>}
              {domain.keyTopics.length > 0 && (
                <div class="domain-block">
                  <p class="domain-label">{copy.keyTopicsLabel}</p>
                  <ul class="topic-list">
                    {domain.keyTopics.map((topic) => (
                      <li>
                        {topic.text}
                        {topic.doc && (
                          <a class="doc-link" href={topic.doc} target="_blank" rel="noopener" title={lang === "pt" ? "Documentação oficial" : "Official documentation"}>
                            docs ↗
                          </a>
                        )}
                      </li>
                    ))}
                  </ul>
                </div>
              )}
              {domain.services.length > 0 && (
                <div class="domain-block">
                  <p class="domain-label">{copy.domainServicesLabel}</p>
                  <div class="chip-row">
                    {domain.services.map((service) => <span class="chip">{service}</span>)}
                  </div>
                </div>
              )}
            </li>
          ))}
        </ul>
      </section>

      <div class="two-column">
        <section class="col">
          <h2 class="block-title">{copy.highlightedServicesTitle}</h2>
          <p class="muted">{copy.highlightedServicesText}</p>
          <div class="chip-row">
            {cert.highlightedServices.map((service) =>
              service.slug ? (
                <a class="chip link" href={`${servicesCatalogBase}/${lang}/services/${service.slug}/`} target="_blank" rel="noopener">
                  {service.name} ↗
                </a>
              ) : (
                <span class="chip">{service.name}</span>
              )
            )}
          </div>
        </section>

        {cert.studyOrder.length > 0 && (
          <section class="col">
            <h2 class="block-title">{copy.studyOrderTitle}</h2>
            <ol class="study-order">
              {cert.studyOrder.map((step) => <li>{step}</li>)}
            </ol>
          </section>
        )}
      </div>

      <section class="resources">
        <h2 class="block-title">{copy.resourcesTitle}</h2>
        <ul class="link-list">
          {cert.resources.map((resource) => (
            <li><a href={resource.url} target="_blank" rel="noopener">{resource.title} ↗</a></li>
          ))}
        </ul>
      </section>
    </div>
  </article>
</BaseLayout>

<style>
  .cert-detail {
    padding: 2.5rem 0 4rem;
  }

  .back-link {
    display: inline-flex;
    margin-bottom: 1.4rem;
    color: var(--text-muted);
    font-size: 0.88rem;
    font-weight: 600;
  }

  .detail-head {
    display: grid;
    gap: 0.6rem;
    margin-bottom: 2rem;
    max-width: 60rem;
  }

  .cert-code {
    color: var(--primary);
    font-size: 0.85rem;
    font-weight: 700;
    letter-spacing: 0.04em;
  }

  .block-title {
    margin: 0 0 1rem;
    font-family: var(--font-display);
    font-size: 1.3rem;
    font-weight: 600;
    letter-spacing: -0.01em;
  }

  .overview {
    padding: 1.4rem;
    margin-bottom: 2.2rem;
  }

  .overview-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(8rem, 1fr));
    gap: 1.1rem;
    margin: 0 0 1.2rem;
  }

  .overview-grid div {
    display: grid;
    gap: 0.25rem;
  }

  .overview-grid dt {
    color: var(--text-muted);
    font-size: 0.76rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.04em;
  }

  .overview-grid dd {
    margin: 0;
    color: var(--text);
    font-size: 0.98rem;
    font-weight: 600;
  }

  .who-for {
    margin: 0;
    padding-top: 1rem;
    border-top: 1px solid var(--line);
    color: var(--text-soft);
    line-height: 1.6;
  }

  .who-for strong {
    color: var(--text);
  }

  .domains {
    margin-bottom: 2.2rem;
  }

  .seed-note {
    margin: -0.4rem 0 1.2rem;
    padding: 0.7rem 0.9rem;
    border-radius: var(--radius-md);
    background: rgba(var(--primary-rgb), 0.07);
    color: var(--text-muted);
    font-size: 0.85rem;
  }

  .domain-list {
    display: grid;
    gap: 1rem;
    margin: 0;
    padding: 0;
    list-style: none;
  }

  .domain-card {
    padding: 1.2rem;
  }

  .domain-top {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 1rem;
  }

  .domain-top h3 {
    margin: 0;
    font-size: 1rem;
    font-weight: 700;
    color: var(--text);
  }

  .weight {
    color: var(--primary);
    font-size: 0.9rem;
    font-weight: 700;
  }

  .weight-bar {
    height: 6px;
    margin: 0.6rem 0 0.8rem;
    border-radius: 999px;
    background: var(--surface-strong);
    overflow: hidden;
  }

  .weight-bar span {
    display: block;
    height: 100%;
    border-radius: 999px;
    background: var(--primary);
  }

  .domain-summary {
    margin: 0 0 0.8rem;
    color: var(--text-soft);
    line-height: 1.6;
  }

  .domain-block {
    margin-top: 0.8rem;
  }

  .domain-label {
    margin: 0 0 0.4rem;
    color: var(--text-muted);
    font-size: 0.76rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.04em;
  }

  .topic-list {
    margin: 0;
    padding-left: 1.1rem;
    color: var(--text-soft);
    line-height: 1.55;
  }

  .topic-list li + li {
    margin-top: 0.35rem;
  }

  .doc-link {
    margin-left: 0.45rem;
    padding: 0.05rem 0.42rem;
    border: 1px solid rgba(var(--primary-rgb), 0.35);
    border-radius: 999px;
    color: var(--primary);
    font-family: var(--font-mono);
    font-size: 0.68rem;
    font-weight: 600;
    text-decoration: none;
    white-space: nowrap;
    vertical-align: 2px;
  }

  .doc-link:hover {
    background: rgba(var(--primary-rgb), 0.1);
  }

  .chip-row {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
  }

  .chip {
    display: inline-flex;
    align-items: center;
    padding: 0.28rem 0.6rem;
    border: 1px solid var(--line);
    border-radius: 999px;
    background: var(--surface);
    color: var(--text-muted);
    font-size: 0.8rem;
  }

  .chip.link {
    color: var(--primary);
    border-color: rgba(var(--primary-rgb), 0.35);
  }

  .two-column {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(18rem, 1fr));
    gap: 2rem;
    margin-bottom: 2.2rem;
  }

  .muted {
    margin: -0.5rem 0 1rem;
    color: var(--text-muted);
    font-size: 0.88rem;
  }

  .study-order {
    margin: 0;
    padding-left: 1.2rem;
    color: var(--text-soft);
    line-height: 1.6;
  }

  .study-order li + li {
    margin-top: 0.5rem;
  }

  .link-list {
    display: grid;
    gap: 0.5rem;
    margin: 0;
    padding: 0;
    list-style: none;
  }

  .link-list a {
    color: var(--primary);
    font-size: 0.92rem;
  }
</style>
