---
import type { CertEntry } from "../lib/certifications";
import type { QuizQuestion } from "../lib/quizzes";
import type { Language } from "../lib/site";

interface Props {
  lang: Language;
  cert: CertEntry;
  questions: QuizQuestion[];
}

const { lang, cert, questions } = Astro.props;

const text = lang === "pt" ? {
  eyebrow: "Simulado",
  title: "Teste seu conhecimento da certificação",
  description: "Uma questão por vez, com correção imediata e explicação. No final, veja o placar por domínio.",
  progress: "Questão",
  best: "Melhor resultado",
  check: "Responder",
  next: "Próxima questão",
  results: "Ver resultado",
  correct: "Correto!",
  wrong: "Não é essa.",
  scoreTitle: "Resultado do simulado",
  byDomain: "Acertos por domínio",
  retry: "Refazer simulado",
  newBest: "Novo recorde pessoal!"
} : {
  eyebrow: "Practice quiz",
  title: "Test your certification knowledge",
  description: "One question at a time, with instant feedback and an explanation. See your per-domain score at the end.",
  progress: "Question",
  best: "Best score",
  check: "Submit answer",
  next: "Next question",
  results: "See results",
  correct: "Correct!",
  wrong: "Not this one.",
  scoreTitle: "Quiz results",
  byDomain: "Score by domain",
  retry: "Retake quiz",
  newBest: "New personal best!"
};

const domainNames = cert.domains.map((domain) => domain.name);
const config = JSON.stringify({
  code: cert.code,
  questions: questions.map((q) => ({ d: q.domainIndex, c: q.correctIndex, e: q.explanation })),
  domains: domainNames,
  labels: {
    correct: text.correct,
    wrong: text.wrong,
    newBest: text.newBest,
    progress: text.progress,
    best: text.best,
    next: text.next,
    results: text.results
  }
});
---

<section class="quiz surface" data-quiz data-quiz-config={config} aria-labelledby="quiz-title">
  <header class="quiz-head">
    <div>
      <span class="eyebrow">{text.eyebrow}</span>
      <h2 class="block-title" id="quiz-title">{text.title}</h2>
      <p class="quiz-intro">{text.description}</p>
    </div>
    <div class="quiz-meta">
      <span class="quiz-progress mono" data-quiz-progress>{text.progress} 1 / {questions.length}</span>
      <span class="quiz-best mono" data-quiz-best hidden></span>
    </div>
  </header>

  <div class="quiz-stage" data-quiz-stage>
    {questions.map((q, qIndex) => (
      <fieldset class="question" data-question={qIndex} hidden={qIndex !== 0}>
        <legend class="question-text">{q.question}</legend>
        <div class="options">
          {q.options.map((option, oIndex) => (
            <button type="button" class="option" data-option={oIndex}>
              <span class="option-letter mono">{String.fromCharCode(65 + oIndex)}</span>
              <span>{option}</span>
            </button>
          ))}
        </div>
        <p class="feedback" data-feedback hidden></p>
        <p class="explanation" data-explanation hidden>{q.explanation}</p>
      </fieldset>
    ))}

    <div class="score-panel" data-score-panel hidden>
      <h3>{text.scoreTitle}</h3>
      <p class="score-line mono" data-score-line></p>
      <p class="score-best" data-score-best hidden></p>
      <h4>{text.byDomain}</h4>
      <ul class="domain-scores" data-domain-scores></ul>
      <button type="button" class="quiz-btn primary" data-quiz-retry>{text.retry}</button>
    </div>
  </div>

  <div class="quiz-actions" data-quiz-actions>
    <button type="button" class="quiz-btn primary" data-quiz-next hidden>{text.next}</button>
  </div>
</section>

<script is:inline>
  (() => {
    const root = document.querySelector("[data-quiz]");
    if (!root) return;

    const config = JSON.parse(root.dataset.quizConfig);
    const storageKey = `aws-cert-quiz:${config.code}`;
    const questions = Array.from(root.querySelectorAll("[data-question]"));
    const nextBtn = root.querySelector("[data-quiz-next]");
    const progressEl = root.querySelector("[data-quiz-progress]");
    const bestEl = root.querySelector("[data-quiz-best]");
    const scorePanel = root.querySelector("[data-score-panel]");
    const total = questions.length;

    let current = 0;
    let answered = false;
    let correctByDomain = {};
    let correctTotal = 0;

    const readBest = () => {
      const raw = localStorage.getItem(storageKey);
      return raw ? Number(raw) : null;
    };

    const paintBest = () => {
      const best = readBest();
      if (best !== null && bestEl) {
        bestEl.textContent = `${config.labels.best}: ${best}/${total}`;
        bestEl.hidden = false;
      }
    };

    const showQuestion = (index) => {
      questions.forEach((q, i) => { q.hidden = i !== index; });
      scorePanel.hidden = true;
      answered = false;
      nextBtn.hidden = true;
      progressEl.textContent = `${config.labels.progress} ${index + 1} / ${total}`;
    };

    const finish = () => {
      questions.forEach((q) => { q.hidden = true; });
      nextBtn.hidden = true;
      progressEl.textContent = `${correctTotal} / ${total}`;

      root.querySelector("[data-score-line]").textContent = `${correctTotal} / ${total} (${Math.round((correctTotal / total) * 100)}%)`;

      const best = readBest();
      const bestNote = root.querySelector("[data-score-best]");
      if (best === null || correctTotal > best) {
        localStorage.setItem(storageKey, String(correctTotal));
        if (best !== null) {
          bestNote.textContent = config.labels.newBest;
          bestNote.hidden = false;
        }
      }
      paintBest();

      const byDomain = root.querySelector("[data-domain-scores]");
      byDomain.innerHTML = "";
      const domainTotals = {};
      config.questions.forEach((q) => { domainTotals[q.d] = (domainTotals[q.d] || 0) + 1; });
      Object.keys(domainTotals).sort((a, b) => a - b).forEach((d) => {
        const li = document.createElement("li");
        const got = correctByDomain[d] || 0;
        const all = domainTotals[d];
        const pct = Math.round((got / all) * 100);
        li.innerHTML = `<span>${config.domains[d] ?? d}</span><span class="mono">${got}/${all}</span><div class="domain-bar"><span style="width:${pct}%"></span></div>`;
        byDomain.appendChild(li);
      });

      scorePanel.hidden = false;
    };

    const reset = () => {
      current = 0;
      correctTotal = 0;
      correctByDomain = {};
      questions.forEach((q) => {
        q.querySelectorAll(".option").forEach((o) => {
          o.classList.remove("is-correct", "is-wrong", "is-picked");
          o.disabled = false;
        });
        q.querySelector("[data-feedback]").hidden = true;
        q.querySelector("[data-explanation]").hidden = true;
      });
      const bestNote = root.querySelector("[data-score-best]");
      bestNote.hidden = true;
      showQuestion(0);
    };

    questions.forEach((q, qIndex) => {
      const meta = config.questions[qIndex];
      q.querySelectorAll(".option").forEach((optionBtn) => {
        optionBtn.addEventListener("click", () => {
          if (answered) return;
          answered = true;

          const picked = Number(optionBtn.dataset.option);
          const isRight = picked === meta.c;
          if (isRight) {
            correctTotal += 1;
            correctByDomain[meta.d] = (correctByDomain[meta.d] || 0) + 1;
          }

          q.querySelectorAll(".option").forEach((o) => {
            const idx = Number(o.dataset.option);
            o.disabled = true;
            if (idx === meta.c) o.classList.add("is-correct");
            if (idx === picked && !isRight) o.classList.add("is-wrong");
            if (idx === picked) o.classList.add("is-picked");
          });

          const feedback = q.querySelector("[data-feedback]");
          feedback.textContent = isRight ? config.labels.correct : config.labels.wrong;
          feedback.classList.toggle("good", isRight);
          feedback.hidden = false;
          q.querySelector("[data-explanation]").hidden = false;

          nextBtn.hidden = false;
          nextBtn.textContent = qIndex === total - 1 ? config.labels.results : config.labels.next;
        });
      });
    });

    nextBtn.addEventListener("click", () => {
      if (current === total - 1) {
        finish();
      } else {
        current += 1;
        showQuestion(current);
      }
    });

    root.querySelector("[data-quiz-retry]").addEventListener("click", reset);

    paintBest();
    showQuestion(0);
  })();
</script>

<style>
  .quiz {
    padding: 1.6rem;
    margin-bottom: 2.2rem;
  }

  .quiz-head {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 1.5rem;
    margin-bottom: 1.2rem;
  }

  .quiz-intro {
    margin: 0.3rem 0 0;
    color: var(--text-muted);
    font-size: 0.9rem;
    max-width: 46rem;
  }

  .quiz-meta {
    display: grid;
    gap: 0.3rem;
    justify-items: end;
    white-space: nowrap;
  }

  .quiz-progress {
    color: var(--primary);
    font-size: 0.82rem;
    font-weight: 700;
  }

  .quiz-best {
    color: var(--text-muted);
    font-size: 0.78rem;
  }

  .question {
    margin: 0;
    padding: 0;
    border: none;
  }

  .question-text {
    margin-bottom: 0.9rem;
    padding: 0;
    color: var(--text);
    font-size: 1.02rem;
    font-weight: 600;
    line-height: 1.55;
  }

  .options {
    display: grid;
    gap: 0.55rem;
  }

  .option {
    display: flex;
    align-items: baseline;
    gap: 0.7rem;
    padding: 0.75rem 0.9rem;
    border: 1px solid var(--line);
    border-radius: var(--radius-md);
    background: var(--surface);
    color: var(--text-soft);
    font-size: 0.92rem;
    line-height: 1.5;
    text-align: left;
    cursor: pointer;
    transition: border-color 140ms ease, background 140ms ease;
  }

  .option:hover:not(:disabled) {
    border-color: rgba(var(--primary-rgb), 0.5);
    background: rgba(var(--primary-rgb), 0.05);
  }

  .option:disabled {
    cursor: default;
    opacity: 0.75;
  }

  .option-letter {
    flex: 0 0 auto;
    color: var(--text-muted);
    font-size: 0.78rem;
    font-weight: 700;
  }

  .option.is-correct {
    border-color: var(--success);
    background: color-mix(in srgb, var(--success) 12%, var(--surface));
    opacity: 1;
  }

  .option.is-wrong {
    border-color: var(--danger);
    background: color-mix(in srgb, var(--danger) 10%, var(--surface));
    opacity: 1;
  }

  .feedback {
    margin: 0.9rem 0 0;
    color: var(--danger);
    font-size: 0.9rem;
    font-weight: 700;
  }

  .feedback.good {
    color: var(--success);
  }

  .explanation {
    margin: 0.4rem 0 0;
    padding: 0.75rem 0.9rem;
    border-left: 3px solid var(--primary);
    border-radius: 0 var(--radius-md) var(--radius-md) 0;
    background: rgba(var(--primary-rgb), 0.06);
    color: var(--text-soft);
    font-size: 0.9rem;
    line-height: 1.6;
  }

  .quiz-actions {
    display: flex;
    justify-content: flex-end;
    margin-top: 1rem;
  }

  .quiz-btn {
    padding: 0.65rem 1.2rem;
    border: 1px solid var(--line);
    border-radius: 999px;
    background: var(--surface);
    color: var(--text-soft);
    font-size: 0.9rem;
    font-weight: 600;
    cursor: pointer;
  }

  .quiz-btn.primary {
    background: var(--primary);
    border-color: var(--primary);
    color: #fff;
  }

  .score-panel h3 {
    margin: 0 0 0.4rem;
    font-family: var(--font-display);
    font-size: 1.25rem;
  }

  .score-line {
    margin: 0 0 0.4rem;
    color: var(--primary);
    font-size: 1.6rem;
    font-weight: 700;
  }

  .score-best {
    margin: 0 0 0.6rem;
    color: var(--success);
    font-weight: 700;
    font-size: 0.9rem;
  }

  .score-panel h4 {
    margin: 1rem 0 0.6rem;
    color: var(--text-muted);
    font-size: 0.8rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.04em;
  }

  .domain-scores {
    display: grid;
    gap: 0.6rem;
    margin: 0 0 1.2rem;
    padding: 0;
    list-style: none;
  }

  .domain-scores :global(li) {
    display: grid;
    grid-template-columns: 1fr auto;
    gap: 0.2rem 0.8rem;
    color: var(--text-soft);
    font-size: 0.88rem;
  }

  .domain-scores :global(.domain-bar) {
    grid-column: 1 / -1;
    height: 5px;
    border-radius: 999px;
    background: var(--surface-strong);
    overflow: hidden;
  }

  .domain-scores :global(.domain-bar span) {
    display: block;
    height: 100%;
    border-radius: 999px;
    background: var(--primary);
  }

  @media (max-width: 720px) {
    .quiz-head {
      flex-direction: column;
    }

    .quiz-meta {
      justify-items: start;
    }
  }
</style>
